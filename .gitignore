# Environment & Secrets (NEVER commit these!)
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
venv/
env/
.venv/

# Uploaded & Generated Files
uploads/*
generated/*
!uploads/.gitkeep
!generated/.gitkeep

# IDE Files
.vscode/
.idea/
*.swp
*.swo

# OS Files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

.env
__pycache__/
*.pyc
*.log